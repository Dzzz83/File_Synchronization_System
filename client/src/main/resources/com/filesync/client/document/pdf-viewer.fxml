<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="8" styleClass="root-pane" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.filesync.client.document.PdfViewerController">
    <padding>
        <Insets bottom="8" left="8" right="8" top="8" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="8">
        <Button fx:id="previousButton" onAction="#previousPage" styleClass="main-vbox" text="Previous" />
        <Button fx:id="nextButton" onAction="#nextPage" styleClass="main-vbox" text="Next" />

        <Label text="Page:" />
        <TextField fx:id="pageField" onAction="#goToPage" prefWidth="60" />
        <Label fx:id="totalPagesLabel" />
        <Button onAction="#goToPage" styleClass="main-vbox" text="Go" />

        <Button onAction="#zoomOut" styleClass="main-vbox" text="Zoom Out" />
        <Button onAction="#zoomIn" styleClass="main-vbox" text="Zoom In" />
        <Button onAction="#fitWidth" styleClass="main-vbox" text="Fit Width" />

        <Label fx:id="statusLabel" style="-fx-font-size: 17; -fx-font-weight: bold;" text="Ready" />
    </HBox>

                <ScrollPane fitToHeight="true" fitToWidth="true" maxWidth="1400.0" VBox.vgrow="ALWAYS">
        <ImageView fx:id="pageImageView" preserveRatio="true" smooth="true" />
    </ScrollPane>
</VBox>
