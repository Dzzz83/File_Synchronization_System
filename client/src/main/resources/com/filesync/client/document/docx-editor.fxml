<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.HTMLEditor?>

<VBox alignment="TOP_CENTER" spacing="10" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.filesync.client.document.DocxEditorController">
    <padding>
        <Insets bottom="8" left="8" right="8" top="8" />
    </padding>

    <HTMLEditor fx:id="htmlEditor" maxWidth="1400.0" prefHeight="578.0" prefWidth="800.0" VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10" stylesheets="@../css/styles.css">
        <Button fx:id="saveButton" onAction="#saveDocument" style="-fx-background-color: #328FDB; -fx-text-fill: white; -fx-font-size: 15;" text="Save" />
        <Button fx:id="cancelButton" onAction="#closeWindow" text="Cancel" />
    </HBox>
</VBox>
