<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.filesync.client.controller.FileExplorerController">
    <padding>
        <Insets bottom="0" left="0" right="0" top="0" />
    </padding>

    <TableView fx:id="fileTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="iconColumn" maxWidth="100.0" prefWidth="50.0" minWidth="30.0">
                <cellValueFactory>
                    <PropertyValueFactory property="icon" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="pathColumn" prefWidth="400.7999725341797" text="File Path" />
            <TableColumn fx:id="lastModifiedColumn" prefWidth="183.20001220703125" text="Last Modified" />
            <TableColumn fx:id="sizeColumn" prefWidth="132.79995727539062" text="Size" />
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="uploadButton" onAction="#handleUpload" text="Upload" />
        <Button fx:id="downloadButton" onAction="#handleDownload" text="Download" />
        <Button fx:id="editButton" onAction="#handleEdit" text="Edit" />
        <Button fx:id="deleteButton" onAction="#handleDelete" text="Delete" />
        <Button fx:id="refreshButton" onAction="#handleRefresh" text="Refresh" />
        <Button onAction="#handleLogout" text="Logout" />
        <Button fx:id="newFolderButton" onAction="#handleNewFolder" text="New Folder" />
    </HBox>
</VBox>
