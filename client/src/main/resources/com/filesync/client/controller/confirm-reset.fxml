   <Pane GridPane.columnSpan="2">
      <children>

          <Label alignment="CENTER" layoutX="46.0" layoutY="-5.0" prefHeight="38.0" prefWidth="246.0" text="Reset Password">
              <font>
                  <Font name="System Bold Italic" size="24.0" />
              </font>
              <textFill>
                  <LinearGradient endX="0.37404580152671746" endY="0.7175572810282236" startX="0.6946564885496183" startY="0.2328245002804823">
                      <stops>
                          <Stop>
