<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="CENTER" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.filesync.client.controller.EditDialogController">
   <children>
      <VBox alignment="CENTER" maxWidth="800.0" spacing="10" styleClass="root-pane" stylesheets="@General-design.css">
          <padding>
              <Insets bottom="10" left="10" right="10" top="10" />
          </padding>
      
          <TextArea fx:id="textArea" maxWidth="800.0" prefHeight="400" prefWidth="600" wrapText="true" />
      
          <ButtonBar>
              <buttons>
                  <Button fx:id="saveButton" defaultButton="true" onAction="#handleSave" text="Save" />
                  <Button fx:id="cancelButton" cancelButton="true" onAction="#handleCancel" text="Cancel" />
              </buttons>
          </ButtonBar>
      </VBox>
   </children>
</VBox>
