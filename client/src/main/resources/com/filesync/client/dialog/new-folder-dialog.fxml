<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.filesync.client.controller.CreateFolderController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    <Label text="Folder name:"/>
    <TextField fx:id="nameField"/>
    <HBox spacing="10" alignment="CENTER">
        <Button text="Create" onAction="#onCreate"/>
        <Button text="Cancel" onAction="#onCancel"/>
    </HBox>
</VBox>