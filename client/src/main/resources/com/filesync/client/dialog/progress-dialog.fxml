<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.filesync.client.dialog.ProgressDialogController">    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>
    <Label fx:id="messageLabel" prefHeight="39.0" prefWidth="106.0" style="-fx-font-size: 18;" styleClass="app-title" stylesheets="@../css/styles.css" text="Processing..." />
    <ProgressBar fx:id="progressBar" prefWidth="300" />
   <HBox prefHeight="3.0" prefWidth="300.0" />
    <Button fx:id="cancelButton" styleClass="password-field" stylesheets="@../css/styles.css" text="Cancel" />
</VBox>
