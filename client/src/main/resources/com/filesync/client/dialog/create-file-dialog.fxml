<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.filesync.client.dialog.CreateFileDialogController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <Label text="New File" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Name:"/>
        <TextField fx:id="nameField" promptText="e.g., document" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Format:"/>
        <ComboBox fx:id="extensionCombo" promptText="Select extension" editable="true" HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="createButton" text="Create" defaultButton="true"/>
        <Button fx:id="cancelButton" text="Cancel" cancelButton="true"/>
    </HBox>
</VBox>