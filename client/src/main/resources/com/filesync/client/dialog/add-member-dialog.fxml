<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="com.filesync.client.controller.AddMemberController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Label text="Search user:"/>
    <TextField fx:id="searchField" promptText="Search by username or email"/>
    <ListView fx:id="resultsList" prefHeight="200"/>
    <Label text="Permission:"/>
    <ComboBox fx:id="permissionBox"/>
    <Button fx:id="addButton" text="Add"/>
    <Button fx:id="closeButton" text="Close"/>
</VBox>