<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.filesync.client.controller.ImageViewerController">
    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>

    <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" pannable="true" fitToWidth="true" fitToHeight="true">
        <ImageView fx:id="imageView" preserveRatio="true" smooth="true" cache="true"/>
    </ScrollPane>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="zoomInButton" text="Zoom In"/>
        <Button fx:id="zoomOutButton" text="Zoom Out"/>
        <Button fx:id="fitButton" text="Fit to Window"/>
        <Button fx:id="originalButton" text="Original Size"/>
    </HBox>
</VBox>