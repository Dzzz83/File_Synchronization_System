<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<GridPane xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.filesync.client.admin.ConfirmResetController"
          alignment="CENTER" hgap="10" vgap="10">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Reset Password" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2"/>

    <Label text="Reset Code:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <TextField fx:id="codeField" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="6-digit code"/>

    <Label text="New Password:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

    <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" alignment="CENTER">
        <Button text="Reset Password" onAction="#handleReset"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</GridPane>