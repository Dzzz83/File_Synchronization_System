<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<GridPane xmlns="http://javafx.com/javafx/17" alignment="CENTER" hgap="10" vgap="10">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Reset Password" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
        <GridPane.margin>
            <Insets bottom="10"/>
        </GridPane.margin>
    </Label>

    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="Your email"/>

    <Label text="Token:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
    <TextField fx:id="tokenField" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="6-digit code"/>

    <Label text="New Password:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

    <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2" alignment="CENTER">
        <Button text="Reset Password" onAction="#handleReset"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</GridPane>